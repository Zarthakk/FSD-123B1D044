<!DOCTYPE html>
<html>
<head>
    <title>Packages</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">
</head>
<body>

<nav class="navbar">TravelX 🌍</nav>

<div class="container">
    <h2>Popular Packages</h2>

<div class="grid">

    <% packages.forEach(p => { %>
        <div class="card">
            <img src="https://picsum.photos/300/200?random=<%= p.id %>">
            <h3><%= p.name %></h3>
            <p>₹<%= p.price %></p>
            <a href="/book/<%= p.id %>" class="btn">Book Now</a>
        </div>
    <% }) %>

</div>

</body>
</html>