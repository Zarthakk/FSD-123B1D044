<%- include("partials/header", { pageTitle: pageTitle }) %>

<main class="page-content centered-page">
  <section class="form-card glass">
    <div class="section-copy">
      <p class="eyebrow">Smart Scheduling</p>
      <h1><%= formTitle %></h1>
      <p><%= helperText %></p>

      <% if (error) { %>
        <div class="alert error-alert"><%= error %></div>
      <% } %>
    </div>

    <form action="<%= formAction %>" method="POST" class="appointment-form">
      <div class="input-group">
        <label for="name">Full Name</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Enter your full name"
          value="<%= appointment ? appointment.name : '' %>"
          required
        />
      </div>

      <div class="input-group">
        <label for="date">Appointment Date</label>
        <input
          type="date"
          id="date"
          name="date"
          value="<%= appointment ? appointment.date : '' %>"
          required
        />
      </div>

      <div class="input-group">
        <label for="time">Appointment Time</label>
        <input
          type="time"
          id="time"
          name="time"
          value="<%= appointment ? appointment.time : '' %>"
          required
        />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary"><%= submitLabel %></button>
        <a href="/appointments" class="btn btn-secondary">Back to Appointments</a>
      </div>
    </form>
  </section>
</main>

<%- include("partials/footer") %>
